# =============================================================================
# Dream Starter Kit — environment variables
# =============================================================================
# Copy this file to `.env` (gitignored) and fill in real values:
#     cp .env.example .env
#
# Every variable here is validated by a zod schema in `packages/config/env`.
# The app FAILS LOUDLY on boot if a required variable is missing or malformed.
#
# SECURITY MODEL — read this:
#   * `NEXT_PUBLIC_*` and `EXPO_PUBLIC_*` vars are COMPILED INTO THE CLIENT
#     BUNDLE and are therefore PUBLIC. Only ever put publishable/anon values
#     there. Treat them as readable by anyone who installs the app.
#   * Everything WITHOUT a `*_PUBLIC_` prefix is SERVER-ONLY. It is read only by
#     Next.js server code and Supabase edge functions. NEVER reference a
#     server-only var from client/mobile code.
#   * The Supabase SERVICE ROLE key bypasses Row-Level Security. It lives ONLY
#     in the Stripe webhook / server context — never in the web client or the
#     mobile app.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase  (Phase 1)
# -----------------------------------------------------------------------------
# Local dev: run `supabase start`; it prints the API URL and the local anon /
# service_role keys (well-known demo JWTs). For a hosted project, copy these
# from Supabase Dashboard -> Project Settings -> API.

# Client-safe (web). Local default URL is http://127.0.0.1:54321
# Commented out so a one-click / v0 deploy doesn't require them upfront — the build
# falls back to placeholder defaults (see apps/nextjs/src/env.ts), so the app deploys
# but is NON-FUNCTIONAL until the real values are set and (on Vercel) you redeploy. Set
# them in Vercel (Project Settings, or the Vercel<->Supabase integration which injects
# them), and UNCOMMENT + fill here for local dev.
# NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Client-safe (mobile). Use your machine's LAN IP (not localhost) so a device
# can reach local Supabase, e.g. http://192.168.1.20:54321
EXPO_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
EXPO_PUBLIC_SUPABASE_ANON_KEY=""

# SERVER-ONLY. Bypasses RLS — used exclusively by edge functions / server code.
# The web app needs it to invite staff from /admin (Users → Create New).
SUPABASE_SERVICE_ROLE_KEY=""

# SERVER-ONLY. Direct Postgres connection for migrations & seeds. Local default
# below. Besides the CLI/CI use, this drives the RUNTIME DB BOOTSTRAP
# (apps/nextjs/src/lib/db/bootstrap.ts): on first server boot the app applies
# supabase/migrations/*.sql itself, so a fresh hosted project needs no manual
# `supabase db push`. On Vercel you can leave it unset — the Supabase
# integration injects POSTGRES_URL_NON_POOLING, which the bootstrap uses as a
# fallback. Either way it must be a DIRECT/SESSION-mode connection (port 5432),
# NOT the transaction pooler (6543) — pooling breaks session advisory locks.
# Set DB_BOOTSTRAP=off to disable the runtime bootstrap (e.g. CI owns migrations).
# TLS (libpq semantics; hosted Supabase's cert chain is rooted in Supabase's OWN
# CA, which no default trust store verifies): sslmode=require|prefer|no-verify =
# encrypted but UNVERIFIED (the hosted default; what the Vercel integration
# injects); sslmode=verify-full = strict verification — supply Supabase's CA via
# NODE_EXTRA_CA_CERTS; sslmode=disable (or a local host with no sslmode) = plaintext.
SUPABASE_DB_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
# DB_BOOTSTRAP="off"

# Shared secret protecting the scheduled `process-reminders` edge function
# (Phase 7). Set it as a Supabase function secret AND in the pg_cron Authorization
# header: `supabase secrets set CRON_SECRET=...`
CRON_SECRET=""


# -----------------------------------------------------------------------------
# Auth — OAuth providers  (Phase 3)
# -----------------------------------------------------------------------------
# Read by the Supabase CLI to substitute into supabase/config.toml for LOCAL dev
# (flip `enabled = true` for the provider there once set). In PRODUCTION these
# live in the Supabase Dashboard -> Authentication -> Providers, NOT in env.

# Google (Google Cloud Console -> Credentials -> OAuth 2.0 client)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=""
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=""

# Apple (Apple Developer -> Services ID + key). Required for iOS App Store when
# you offer other social logins (App Store guideline 4.8).
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=""
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=""


# -----------------------------------------------------------------------------
# App URLs  (Phase 1)
# -----------------------------------------------------------------------------
# Public web origin — the single source of truth for every absolute URL the app
# emits (auth/OAuth/magic-link redirects, Stripe return URLs, OG tags). Resolved
# in apps/nextjs/src/lib/site-url.ts with this precedence:
#   1. NEXT_PUBLIC_SITE_URL                       (explicit override; set below for a custom domain)
#   2. NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL  (auto-injected by Vercel — stable prod domain)
#   3. NEXT_PUBLIC_VERCEL_URL                      (auto-injected by Vercel — per-deployment)
#   4. NEXT_PUBLIC_APP_URL                         (this — the local/dev default)
# => On Vercel the deployed URL is detected automatically; you only need to set
#    NEXT_PUBLIC_SITE_URL if you serve from a custom domain. (You must still set
#    the Supabase Site URL + Redirect URLs in the dashboard — see README -> Deploy.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional custom-domain override for the resolver above (no trailing slash),
# e.g. https://app.example.com. Leave blank to auto-detect on Vercel / use the
# local default. The two NEXT_PUBLIC_VERCEL_* values are provided by Vercel and
# should NOT be set by hand.
# NEXT_PUBLIC_SITE_URL=""

# Where the mobile app reaches server routes (AI proxy, Stripe checkout).
# In dev, your web app's LAN origin, e.g. http://192.168.1.20:3000
EXPO_PUBLIC_API_URL="http://localhost:3000"


# -----------------------------------------------------------------------------
# AI — Vercel AI Gateway  (Phase 6)
# -----------------------------------------------------------------------------
# SERVER-ONLY. One credential fronting all providers (Claude is the default
# model). On Vercel, OIDC tokens are injected automatically and this can be
# omitted. Get a key at https://vercel.com/ai-gateway
# The model slug is NOT an env var — it's centralized in packages/config
# (DEFAULT_AI_MODEL, e.g. "anthropic/claude-sonnet-4.x") and is swappable.
AI_GATEWAY_API_KEY=""


# -----------------------------------------------------------------------------
# Stripe — web subscriptions  (Phase 5)
# -----------------------------------------------------------------------------
# SERVER-ONLY secret key (test mode starts with sk_test_...).
STRIPE_SECRET_KEY=""

# SERVER-ONLY webhook signing secret for the SUPABASE EDGE FUNCTION endpoint
# (mirrors products/prices/subscriptions into the RLS public.* tables).
# Local: `stripe listen --forward-to http://127.0.0.1:54321/functions/v1/stripe-webhook`
# prints whsec_... Hosted: Stripe Dashboard -> Developers -> Webhooks -> that endpoint.
STRIPE_WEBHOOK_SECRET=""

# SERVER-ONLY webhook signing secret for the PAYLOAD endpoint
# (/cms-api/stripe/webhooks via @payloadcms/plugin-stripe — mirrors
# customer.subscription.* into the CMS `subscriptions` collection). This is a
# SECOND Stripe webhook endpoint with its own whsec_. Local: run a second
# `stripe listen --forward-to localhost:3000/cms-api/stripe/webhooks`.
STRIPE_WEBHOOKS_ENDPOINT_SECRET=""

# Client-safe publishable key (pk_test_...). Reserved for client-side Stripe.js
# / Elements (e.g. in-page card capture). NOT required by the default flow,
# which uses server-created Checkout sessions (redirect to session.url).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Plans are authored in the Payload CMS (Commerce → Plans) and synced to
# Stripe automatically when saved — you do NOT create products or prices in
# the Stripe dashboard by hand. The edge-function webhook mirrors the
# resulting products/prices back into the DB. So just set STRIPE_SECRET_KEY
# above, seed the CMS, and save a plan to push it.
#
# LEGACY (optional, unused by the default plan-driven checkout). Kept only for
# backward compatibility with older custom flows.
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_YEARLY=""

# Used by the Stripe webhook (edge function) for the guest-checkout invite
# redirect (→ /accept-invite). Defaults to NEXT_PUBLIC_APP_URL / localhost if
# unset. Set to your site origin in production.
SITE_URL=""


# -----------------------------------------------------------------------------
# Payload CMS — content backend (owns the `cms` Postgres schema)
# -----------------------------------------------------------------------------
# SERVER-ONLY. Payload runs only on the server; NONE of these are bundled into the
# client. Payload connects to the SAME Supabase Postgres but as a dedicated
# least-privilege role (payload_cms) scoped to the `cms` schema — NOT the
# service-role key. Local: the role + schema are created by
# supabase/payload/00_cms_role.sql (applied automatically by `supabase db reset`),
# so KEEP the values below in your local .env (they match that script).
# Hosted: BOTH PAYLOAD_DATABASE_URL and PAYLOAD_SECRET can be LEFT UNSET — they
# are derived deterministically from SUPABASE_SERVICE_ROLE_KEY
# (apps/nextjs/src/lib/cms/derived-credentials.ts) and the runtime DB bootstrap
# creates the role with the derived password on first boot. Setting them
# explicitly always overrides: choose a real password, put it in this URL, and
# the bootstrap creates the role with it (create-only: it never alters an
# existing role's password — rotate by hand). Rotating the service-role key
# changes the derived values — set explicit vars or update the role password.
# Never reuse the local dev password on a hosted database.
#
# Connection string for the payload_cms role. Note search_path=cms in the options
# query param (percent-encode the password if it has special characters). Use the
# DIRECT or SESSION-mode connection (port 5432), NOT the transaction pooler
# (6543) — it breaks Drizzle's prepared statements. Same TLS semantics as
# SUPABASE_DB_URL above (hosted: append &sslmode=require); always keep the
# ?options=-c%20search_path%3Dcms suffix.
PAYLOAD_DATABASE_URL="postgresql://payload_cms:payload_local_dev_only@127.0.0.1:54322/postgres?options=-c%20search_path%3Dcms"

# Random 32+ char secret for Payload's admin auth / field encryption.
# Generate: `openssl rand -base64 32`. Hosted: optional — derived from
# SUPABASE_SERVICE_ROLE_KEY when unset (see PAYLOAD_DATABASE_URL note above).
PAYLOAD_SECRET=""

# Shared secret guarding the draft-preview entry route (/next/preview), used by
# Payload Live Preview. Optional; when unset, the preview route is open in dev.
PAYLOAD_PREVIEW_SECRET=""

# Supabase Storage (S3) for Payload media — the dedicated public-read `cms-media`
# bucket. Local values below (S3 protocol is enabled in supabase/config.toml). For
# hosted, copy the endpoint/region and create an access key pair at
# Supabase Dashboard -> Project Settings -> Storage -> S3 connection.
S3_ENDPOINT="http://127.0.0.1:54321/storage/v1/s3"
S3_REGION="local"
S3_ACCESS_KEY_ID="stub"            # local stub; hosted: real access key id
S3_SECRET_ACCESS_KEY=""            # local: your local anon key (`supabase status`); hosted: real secret
S3_BUCKET="cms-media"

# Origin hosting the Payload REST API, for the MOBILE app to read content (the web
# app reads same-origin). In dev, your web app's LAN origin.
EXPO_PUBLIC_CMS_URL="http://localhost:3000"


# -----------------------------------------------------------------------------
# Expo / EAS — mobile build & push  (Phases 3 & 7)
# -----------------------------------------------------------------------------
# EAS project id (also set in apps/expo/app.json -> extra.eas.projectId).
# Used for Expo Push. Find it via `eas init` / Expo dashboard.
EXPO_PUBLIC_EAS_PROJECT_ID=""

# OAuth deep-link scheme for native auth redirects (matches app.json `scheme`).
EXPO_PUBLIC_AUTH_SCHEME="dreamstarter"
