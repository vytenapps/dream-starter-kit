{
  "name": "dream-starter-kit",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": "^22.21.0 || ^24.0.0",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:gen-migrations": "pnpm -F @acme/nextjs db:gen-migrations",
    "db:gen-types": "supabase gen types typescript --local > packages/api/src/types.ts",
    "db:reset": "supabase db reset && pnpm cms:migrate",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "cms:gen-types": "pnpm -F @acme/nextjs payload generate:types",
    "cms:migrate": "pnpm -F @acme/nextjs payload migrate",
    "cms:migrate:create": "pnpm -F @acme/nextjs payload migrate:create",
    "cms:seed": "pnpm -F @acme/nextjs seed",
    "cms:backfill-users": "pnpm -F @acme/nextjs backfill-users",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @acme/nextjs...",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "license:check": "pnpm licenses list --prod --json | node tooling/scripts/check-licenses.mjs",
    "postinstall": "pnpm lint:ws",
    "test": "turbo run test",
    "test:e2e": "pnpm -F @acme/web-e2e test:e2e",
    "test:rls": "pnpm -F @acme/rls-tests test:rls",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@acme/prettier-config": "workspace:*",
    "@turbo/gen": "^2.5.8",
    "dotenv-cli": "^10.0.0",
    "prettier": "catalog:",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config"
}
