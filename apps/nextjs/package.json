{
  "name": "@acme/nextjs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "pnpm with-env next dev",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "payload": "pnpm with-env payload",
    "db:gen-migrations": "tsx scripts/generate-supabase-migrations.ts",
    "seed": "pnpm with-env node --import tsx --import ./scripts/register-cli-loaders.mjs src/payload/seed.ts",
    "backfill-users": "pnpm with-env node --import tsx --import ./scripts/register-cli-loaders.mjs src/payload/backfill-users.ts",
    "start": "pnpm with-env next start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@acme/api": "workspace:*",
    "@acme/app": "workspace:*",
    "@acme/cms": "workspace:*",
    "@acme/config": "workspace:*",
    "@acme/ext-billing": "workspace:*",
    "@acme/ext-chat": "workspace:*",
    "@acme/ext-chat-adapter-sendblue": "workspace:*",
    "@acme/ext-chat-adapter-slack": "workspace:*",
    "@acme/ext-dashboard": "workspace:*",
    "@acme/ext-docs": "workspace:*",
    "@acme/ext-kit": "workspace:*",
    "@acme/ext-notifications": "workspace:*",
    "@acme/ext-reminders": "workspace:*",
    "@acme/mcp": "workspace:*",
    "@acme/ui": "workspace:*",
    "@hookform/resolvers": "catalog:",
    "@marsidev/react-turnstile": "^1.5.3",
    "@payloadcms/db-postgres": "catalog:",
    "@payloadcms/live-preview-react": "catalog:",
    "@payloadcms/next": "catalog:",
    "@payloadcms/plugin-form-builder": "catalog:",
    "@payloadcms/plugin-nested-docs": "catalog:",
    "@payloadcms/plugin-seo": "catalog:",
    "@payloadcms/plugin-stripe": "catalog:",
    "@payloadcms/richtext-lexical": "catalog:",
    "@payloadcms/storage-s3": "catalog:",
    "@payloadcms/ui": "catalog:",
    "@stripe/react-stripe-js": "^3.7.0",
    "@stripe/stripe-js": "^5.10.0",
    "@supabase/ssr": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "catalog:",
    "ai": "catalog:",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "graphql": "catalog:",
    "lucide-react": "^1.17.0",
    "motion": "^12.0.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "payload": "catalog:",
    "pg": "8.20.0",
    "radix-ui": "^1.4.3",
    "react": "catalog:react19",
    "react-colorful": "^5.6.1",
    "react-dom": "catalog:react19",
    "react-hook-form": "catalog:",
    "sharp": "catalog:",
    "sonner": "^2.0.7",
    "stripe": "catalog:",
    "vaul": "^1.1.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/ext-tools": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tailwind-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "catalog:",
    "@types/pg": "8.20.0",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "eslint": "catalog:",
    "jiti": "^2.5.1",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@acme/prettier-config"
