# Payload auto-generates this import map ("DO NOT MODIFY") with its own style, and
# Prettier can't stably format it: its writer can't target the parenthesized
# `(payload)` path, and the sort-imports plugin is non-idempotent on the alias
# imports. Excluded from formatting — it's regenerated by `payload generate:importmap`.
src/app/(payload)/admin/importMap.js

# Payload-generated database migrations (TS + drizzle JSON snapshots), emitted by
# `pnpm cms:migrate:create`. They ship verbatim and are never hand-edited, so we
# don't hold them to Prettier's style.
src/payload/migrations/

# Extension framework outputs, regenerated wholesale by `pnpm ext sync` —
# machine-owned, byte-compared by the registry drift test, never hand-edited.
src/ext/*.generated.ts
ext-packages.generated.json
src/app/(frontend)/(app)/x/
src/app/(frontend)/(public)/x/
